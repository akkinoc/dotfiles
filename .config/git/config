[alias]
a = add
aa = add -A
ap = add -p
b = branch -vv
ba = branch -avv
c = commit
ca = commit --amend --no-edit
cl = clean -df
co = checkout
cp = cherry-pick
d = diff -p --stat
f = fetch --all
ge = grep -I
ig = "!f() { IFS=,; curl -LSfs \"https://www.toptal.com/developers/gitignore/api/$*\"; }; f"
l = log --graph --name-status
ll = log --date=short --pretty=line
ls = ls-files -s --abbrev
m = merge --no-edit
p = pull
r = rebase
ri = rebase -i
rs = restore
s = status
sh = show -p --stat
st = stash
std = stash drop
sti = stash push -u
stl = stash list
sto = stash pop
sts = stash show
sw = switch
t = tag
tl = tag -ln
u = push -u

[color "grep"]
filename = magenta
lineNumber = green
match = bold red
separator = cyan

[commit]
cleanup = scissors
gpgSign = true
verbose = true

[core]
quotePath = false

[diff]
colorMoved = dimmed-zebra

[fetch]
prune = true
pruneTags = true

[format]
pretty = fuller

[gpg]
format = ssh

[gpg "ssh"]
allowedSignersFile = ~/.ssh/allowed-signers
program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[grep]
lineNumber = true
patternType = extended

[init]
defaultBranch = main

[interactive]
diffFilter = \"$HOMEBREW_PREFIX/share/git-core/contrib/diff-highlight/diff-highlight\"
singleKey = true

[log]
abbrevCommit = true
date = iso
follow = true

[merge]
ff = false

[pager]
diff = \"$HOMEBREW_PREFIX/share/git-core/contrib/diff-highlight/diff-highlight\" | less
log = \"$HOMEBREW_PREFIX/share/git-core/contrib/diff-highlight/diff-highlight\" | less
show = \"$HOMEBREW_PREFIX/share/git-core/contrib/diff-highlight/diff-highlight\" | less

[pretty]
line = %C(auto)%h%C(reset) %C(blue)%ad%C(reset) %C(magenta)%<(13,trunc)%an%C(reset) %s%C(auto)%d%C(reset)

[pull]
rebase = true

[push]
default = current
followTags = true

[rebase]
abbreviateCommands = true
autoSquash = true
autoStash = true
stat = true

[status]
branch = true
short = true
showUntrackedFiles = all

[tag]
gpgSign = true
sort = -version:refname

[url "git@github.com:"]
insteadOf = https://github.com/

[user]
email = akkinoc@gmail.com
name = Akihiro Kondo
signingKey = ~/.ssh/akkinoc.pub
